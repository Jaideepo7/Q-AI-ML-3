# ============================================================================
# ADAPTIVE QUIZ SYSTEM - ENVIRONMENT VARIABLES
# ============================================================================
# 
# Instructions:
# 1. Copy this file to .env (without .template extension)
# 2. Fill in your actual credentials below
# 3. NEVER commit .env to git (it's in .gitignore)
#
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE CREDENTIALS
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
#
# Your Supabase project URL (ends with .supabase.co)
SUPABASE_URL=

# Your Supabase anon/public API key (starts with eyJ...)
# This is safe to use in client-side code
SUPABASE_KEY=

# ----------------------------------------------------------------------------
# ANTHROPIC API CREDENTIALS (for Claude-based questions)
# ----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/settings/keys
#
# Your Anthropic API key (starts with sk-ant-api03-)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ----------------------------------------------------------------------------
# GOOGLE GEMINI API CREDENTIALS (for Gemini-based questions)
# ----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
#
# Your Google Gemini API key
GEMINI_API_KEY=

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================

# Database connection pool size (default: 10)
# DB_POOL_SIZE=10

# Question generation model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum tokens for question generation (default: 1000)
# MAX_TOKENS=1000

# Default number of questions per session (default: 10)
# DEFAULT_QUESTIONS=10

# ============================================================================
# NOTES
# ============================================================================
#
# Security Best Practices:
# - NEVER commit this file to version control
# - NEVER share your API keys publicly
# - Rotate keys if they are exposed
# - Use different keys for development and production
# - Keep this file readable only by you: chmod 600 .env
